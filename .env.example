# NASA API key — get a free key at https://api.nasa.gov
# Falls back to DEMO_KEY (rate-limited to 30 requests/hour)
NASA_API_KEY=DEMO_KEY

# Google Cloud project - required for Vertex AI Gemini access
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# GCP region (use "global" for models that require global endpoints, e.g. gemini-3-flash-preview)
GOOGLE_CLOUD_LOCATION=global

# Gemini model name (optional, defaults to gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview

# Logging level (DEBUG, INFO, WARNING, ERROR). Defaults to INFO.
LOG_LEVEL=INFO
